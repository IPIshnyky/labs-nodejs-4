<!DOCTYPE html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <title>Tasks</title>
    <link rel="stylesheet" href="/css/index.css" />
  </head>
  <body>
    <main>
      <h1>Dashboard</h1>

      <% 
        const getSortLink = (label, field) => {
          const isCurrent = currentSort === field;
          const nextOrder = isCurrent && currentOrder === 'asc' ? 'desc' : 'asc';
          const icon = isCurrent ? (currentOrder === 'asc' ? '▲' : '▼') : '↕';
          return `<a href="/?sort=${field}&order=${nextOrder}" class="sort-link">${label} ${icon}</a>`;
        }
      %>

      <% if (tasks.length === 0) { %>
        <p>No tasks yet.</p>
      <% } else { %>
        <table class="task-table">
          <thead>
            <tr>
              <th><%- getSortLink('Title', 'title') %></th>
              <th><%- getSortLink('Date', 'date') %></th>
              <th><%- getSortLink('Priority', 'priority') %></th>
              <th><%- getSortLink('Status', 'status') %></th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% tasks.forEach(task => { %>
              <tr class="<%= task.completed ? 'row-done' : '' %>">
                <td><%= task.title %></td>
                <td><%= task.date %></td>
                <td>
                  <span class="badge badge-<%= task.priority %>"><%= task.priority %></span>
                </td>
                <td><%= task.completed ? 'Done' : 'Pending' %></td>
                <td>
                  <div class="actions">
                    <form method="POST" action="/tasks/<%= task.id %>/toggle" style="display:inline;">
                      <button type ="submit">
                        <%= task.completed ? 'Undo' : 'Complete' %>
                      </button>
                    </form>
                     <a href="/tasks/<%= task.id %>/edit">Edit</a>
                      <form method="POST" action="/tasks/<%= task.id %>/delete" style="display:inline;">
                        <button type="submit">Delete</button>
                      </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>

      <a href="/tasks/new" class="btn">+ New Task</a>
      <a href="/tasks/reschedule-overdue" class="btn">Reschedule Overdue</a>
      <% if (currentSort) { %>
        <a href="/" class="btn">Reset sorting</a>
      <% } %>
    </main>

    <%- include('partials/footer') %>
  </body>
</html>
